---
interface Props {
  city: string | null;
}

const { city } = Astro.props;
const place = city?.trim() ? city.trim() : "Area";
---

<p class="national-dispatch-disclaimer">
  National Dispatch Hub - Connecting to Local {place} Response Team.
</p>

<style>
  .national-dispatch-disclaimer {
    margin: 0.4rem 0 0;
    padding: 0 0.35rem;
    font-size: 9px;
    line-height: 1.35;
    color: #6b7280; /* gray-500 */
    text-align: center;
  }
</style>
