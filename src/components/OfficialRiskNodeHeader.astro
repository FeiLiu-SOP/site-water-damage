---
/**
 * Brand verification anchor above Value Protection Calculator (Pinterest / search parity).
 * 教堂 stewardship：与 FixitGrid dispatch 指纹解耦，仍保留 ZIP 教育锚点。
 */
const { zipCode, stewardshipMode = false } = Astro.props as {
  zipCode?: string | null | undefined;
  stewardshipMode?: boolean;
};
const zip5 = String(zipCode ?? "")
  .replace(/\D/g, "")
  .slice(0, 5);
const line = stewardshipMode
  ? zip5.length === 5
    ? `ZIP-sector education reference · ${zip5} — community stewardship context (non-commercial)`
    : "Community stewardship education reference (non-commercial)"
  : zip5.length === 5
    ? `Official Node: FixitGrid Local Dispatch Network · ZIP ${zip5}`
    : "Official Node: FixitGrid Local Dispatch Network";
---

<div class="brand-verification-anchor" role="region" aria-label={line}>
  <p class="brand-verification-anchor__line">{line}</p>
</div>

<style>
  .brand-verification-anchor {
    box-sizing: border-box;
    width: 100%;
    margin: 0;
    padding: 1rem 0.5rem; /* py-4 */
    border-bottom: 1px solid #f3f4f6; /* border-gray-100 */
  }
  .brand-verification-anchor__line {
    margin: 0;
    font-size: 10px; /* text-[10px] */
    line-height: 1.4;
    letter-spacing: 0.2em; /* tracking-[0.2em] */
    text-transform: uppercase;
    text-align: center;
    color: #9ca3af; /* text-gray-400 */
    font-weight: 500;
  }
</style>
