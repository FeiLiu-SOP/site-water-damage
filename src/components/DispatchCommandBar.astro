---
/**
 * Mobile-only sticky conversion dock (slug pages). Brand + collection copy per brief.
 */
import { ACTIVE_COLLECTION, type ActiveCollectionKey } from "../active-collection";
import { getBrand, siteConfig } from "../site-config";

export interface Props {
  city: string;
  zip: string;
  nicheLabel: string;
  slugSeed: string;
}

const BRAND_DISPLAY = "FixitGrid Local Dispatch Network";

const COLLECTION_COMMAND: Record<
  ActiveCollectionKey,
  { left: string; right: string }
> = {
  "water-damage": { left: "Mitigation Desk", right: "Emergency Extraction" },
  plumbing: { left: "Pipe Safety Hub", right: "Emergency Dispatch" },
  "plumbing-v2": { left: "Pipe Safety Hub", right: "Emergency Dispatch" },
  roofing: { left: "Roofing Audit", right: "Structural Command" },
  "siding-services": { left: "Envelope Audit", right: "Professional Retrofit" },
  pestcontrol: { left: "Eradication Unit", right: "Secure Property" },
};

function viewerCount(seed: string): number {
  let h = 0;
  for (let i = 0; i < seed.length; i++) {
    h = (h * 33 + seed.charCodeAt(i)) >>> 0;
  }
  return 2 + (h % 3);
}

const { city, zip, nicheLabel, slugSeed } = Astro.props;
const brandRef = getBrand(Astro.url.hostname);
const brandDisplay = BRAND_DISPLAY;
const cmd = COLLECTION_COMMAND[ACTIVE_COLLECTION] ?? COLLECTION_COMMAND.roofing;
const zipClean = zip.replace(/\D/g, "");
const zipDisplay = zipClean.length === 5 ? zipClean : zip.trim() || "local";
const zLabel = nicheLabel.trim() || "Service";
const viewers = viewerCount(slugSeed);
const cityDisplay = city.trim() || "Local";
const phoneE164 = siteConfig.phoneE164.trim();
const telHref = `tel:${phoneE164}`;
---

<div class="dispatch-cmd-root" aria-hidden="false" title={`${brandRef.short} mobile dispatch`}>
  <div class="dispatch-cmd-ticker" role="status">
    {zLabel} Asset at Risk in {zipDisplay} - {viewers} owners currently viewing this audit.
  </div>
  <div class="dispatch-cmd-bar">
    <div class="dispatch-cmd-bar-main">
      <div class="dispatch-cmd-left">
        <span class="dispatch-cmd-pulse-dot" aria-hidden="true"></span>
        <span class="dispatch-cmd-left-text">{cmd.left}</span>
        <span class="dispatch-cmd-sep" aria-hidden="true">|</span>
        <span class="dispatch-cmd-mid-text">{cmd.right}</span>
      </div>
      <a
        class="dispatch-cmd-tel"
        href={telHref}
        aria-label={`Call ${brandDisplay} — ${siteConfig.phoneDisplay}`}
      >
        CALL
      </a>
    </div>
    <p class="dispatch-cmd-micro">
      National Dispatch Hub - Connecting to Local {cityDisplay} Response Team.
    </p>
  </div>
</div>

<style>
  .dispatch-cmd-root {
    position: fixed;
    left: 0;
    bottom: 0;
    width: 100%;
    z-index: 9999;
    display: none;
    flex-direction: column;
    align-items: stretch;
    padding-bottom: env(safe-area-inset-bottom, 0px);
    box-sizing: border-box;
  }
  @media (max-width: 1023px) {
    .dispatch-cmd-root {
      display: flex;
    }
  }
  .dispatch-cmd-ticker {
    min-height: 12px;
    height: 12px;
    line-height: 12px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 0 8px;
    box-sizing: border-box;
    background: #fefce8;
    color: #78350f;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .dispatch-cmd-bar {
    background: #0b2d5c;
    color: #e2e8f0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }
  .dispatch-cmd-bar-main {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    height: 75px;
    min-height: 75px;
    max-height: 75px;
    box-sizing: border-box;
  }
  .dispatch-cmd-left {
    flex: 0 1 auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: 0.35rem;
    padding: 0 0.5rem 0 0.65rem;
    min-width: 0;
    font-size: clamp(0.62rem, 2.4vw, 0.72rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.15;
  }
  .dispatch-cmd-pulse-dot {
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 1px rgba(34, 197, 94, 0.35);
    animation: dispatch-cmd-pulse 2s ease-in-out infinite;
  }
  @keyframes dispatch-cmd-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.55;
      transform: scale(0.92);
    }
  }
  .dispatch-cmd-left-text {
    flex-shrink: 0;
    color: #f8fafc;
  }
  .dispatch-cmd-sep {
    flex-shrink: 0;
    color: rgba(248, 250, 252, 0.45);
    font-weight: 700;
  }
  .dispatch-cmd-mid-text {
    min-width: 0;
    color: rgba(226, 232, 240, 0.92);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .dispatch-cmd-tel {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #b91c1c;
    color: #ffffff;
    font-weight: 900;
    font-size: clamp(0.85rem, 3.5vw, 1rem);
    letter-spacing: 0.06em;
    text-decoration: none;
    text-transform: uppercase;
    min-width: 0;
  }
  .dispatch-cmd-tel:hover,
  .dispatch-cmd-tel:focus-visible {
    background: #991b1b;
    color: #ffffff;
    outline: none;
  }
  .dispatch-cmd-micro {
    margin: 0;
    padding: 0.2rem 0.5rem 0.28rem;
    font-size: 9px;
    line-height: 1.25;
    font-weight: 600;
    color: rgba(226, 232, 240, 0.72);
    text-align: center;
    background: #0b2d5c;
    border-top: 1px solid rgba(148, 163, 184, 0.2);
  }
</style>

<style is:global>
  @media (max-width: 1023px) {
    body:has(.dispatch-cmd-root) {
      padding-bottom: max(
        5rem,
        calc(12px + 75px + 2.25rem + env(safe-area-inset-bottom, 0px))
      );
    }
  }
</style>
