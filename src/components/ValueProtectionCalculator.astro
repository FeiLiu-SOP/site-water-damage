---
/**
 * First-fold "value protection" block: anchors visually to injected median home USD.
 * SSR-first: full layout and numbers without hydration; range updates via tiny inline script.
 */
interface Props {
  homeUsd: number | null;
  zLabel: string | null;
  city: string | null;
  accent: string;
  domPrefix: string | null;
}

const { homeUsd, zLabel, city, accent, domPrefix } = Astro.props;
const rootId = domPrefix ? `${domPrefix}-value-calculator` : "value-calculator-root";
const wrapClass = ["value-protection-calculator", domPrefix ? `${domPrefix}--value-calculator` : null].filter(Boolean);

const hasValue = typeof homeUsd === "number" && Number.isFinite(homeUsd) && homeUsd > 0;
const formattedHome = hasValue
  ? new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: "USD",
      maximumFractionDigits: 0,
    }).format(homeUsd!)
  : null;

const cityLine = city ? `${city}` : "this area";
const defaultPct = 12;
---

<section
  class:list={wrapClass}
  id={rootId}
  style={`--vpc-accent:${accent};`}
  data-vpc-usd={hasValue ? String(Math.round(homeUsd!)) : ""}
  data-vpc-default-pct={String(defaultPct)}
  aria-labelledby={`${rootId}-title`}
>
  <div class="vpc-inner">
    <h2 class="vpc-title" id={`${rootId}-title`}>Value Protection Calculator</h2>
    <p class="vpc-lead">
      First-screen asset anchor for {cityLine}
      {zLabel ? (
        <>
          {" "}
          <span class="vpc-zlabel">({zLabel} benchmark)</span>
        </>
      ) : null}
    </p>
    {
      hasValue ? (
        <>
          <div class="vpc-hero-amount" style={`color:var(--vpc-accent,${accent});`}>
            <span class="vpc-hero-label">Protected home value (aligned)</span>
            <span class="vpc-hero-number">{formattedHome}</span>
          </div>
          <div class="vpc-controls">
            <label class="vpc-range-label" for={`${rootId}-range`}>
              Scenario stress — estimated exposure (%)
            </label>
            <input
              id={`${rootId}-range`}
              class="vpc-range"
              type="range"
              min="5"
              max="40"
              step="1"
              value={String(defaultPct)}
            />
            <div class="vpc-readout">
              <span class="vpc-readout-label">Illustrative exposure at this stress</span>
              <output class="vpc-readout-value" id={`${rootId}-out`} for={`${rootId}-range`}>
                —
              </output>
            </div>
          </div>
          <p class="vpc-foot">
            Illustrative math only — call to scope real loss scenarios for your property.
          </p>
        </>
      ) : (
        <div class="vpc-fallback">
          <p class="vpc-fallback-text">
            Local median benchmark not on file for this node. Call intake to align a protected-asset figure to your
            address and coverage goals.
          </p>
        </div>
      )
    }
  </div>
</section>

{hasValue ? (
  <script
    is:inline
    set:html={`(function(){var r=document.getElementById(${JSON.stringify(
      rootId,
    )});if(!r)return;var u=r.getAttribute("data-vpc-usd");var h=u?parseInt(u,10):0;if(!h||!isFinite(h))return;var g=r.querySelector("input[type=range]"),o=r.querySelector("output");if(!g||!o)return;function f(n){return new Intl.NumberFormat("en-US",{style:"currency",currency:"USD",maximumFractionDigits:0}).format(n)}function s(){var p=+g.value||0;o.textContent=f(Math.round(h*p/100))}g.addEventListener("input",s);s();})();`}
  />
) : null}

<style>
  .value-protection-calculator {
    margin: 1rem 0 1.25rem;
    border-radius: 14px;
    border: 2px solid rgba(15, 23, 42, 0.12);
    background: linear-gradient(145deg, #f8fafc 0%, #ffffff 55%, #f1f5f9 100%);
    box-shadow: 0 14px 40px rgba(15, 23, 42, 0.12);
    overflow: visible;
  }
  .vpc-inner {
    padding: 1rem 1.1rem 1.15rem;
    max-width: 100%;
  }
  .vpc-title {
    margin: 0 0 0.35rem;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #0f172a;
  }
  .vpc-lead {
    margin: 0 0 0.85rem;
    font-size: 0.95rem;
    color: #475569;
    line-height: 1.45;
  }
  .vpc-zlabel {
    font-weight: 700;
    color: #0f172a;
  }
  .vpc-hero-amount {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.85rem;
    padding: 0.75rem 0.85rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.08);
  }
  .vpc-hero-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #64748b;
  }
  .vpc-hero-number {
    font-size: clamp(1.55rem, 4.5vw, 2.1rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .vpc-controls {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .vpc-range-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: #334155;
  }
  .vpc-range {
    width: 100%;
    accent-color: var(--vpc-accent, #2563eb);
  }
  .vpc-readout {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin-top: 0.25rem;
    padding: 0.55rem 0.65rem;
    border-radius: 10px;
    background: #0b1220;
    color: #e2e8f0;
  }
  .vpc-readout-label {
    font-size: 0.75rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .vpc-readout-value {
    font-size: 1.25rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }
  .vpc-foot {
    margin: 0.65rem 0 0;
    font-size: 0.78rem;
    color: #64748b;
    line-height: 1.4;
  }
  .vpc-fallback {
    padding: 0.65rem 0.5rem 0.15rem;
  }
  .vpc-fallback-text {
    margin: 0;
    font-size: 0.92rem;
    color: #475569;
    line-height: 1.5;
  }
</style>
