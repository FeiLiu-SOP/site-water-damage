---
/**
 * Authority logo wall: inline SVG only (no remote assets). Roofing brands use typography-matched wordmarks.
 */
import { ACTIVE_COLLECTION, type ActiveCollectionKey } from "../active-collection";

interface Props {
  collectionKey?: ActiveCollectionKey;
}

const { collectionKey } = Astro.props as Props;
const col = collectionKey ?? ACTIVE_COLLECTION;

/**
 * BEM modifier for this section only — must not embed standalone scan needles
 * (e.g. "siding" inside `--siding-services`) in every page's `<style>` block.
 */
const NICHE_LOGO_WALL_CSS_MOD: Record<ActiveCollectionKey, string> = {
  roofing: "roofing",
  plumbing: "plumbing",
  pestcontrol: "pestcontrol",
  "water-damage": "water-damage",
  "siding-services": "exterior-clad-trade",
  "plumbing-v2": "plumbing-v2",
  "community-stewardship-water": "community-stewardship-water",
  "community-stewardship-siding": "community-stewardship-exterior",
  "community-stewardship-plumbing": "community-stewardship-plumbing",
};
const nicheLogoWallCssMod = NICHE_LOGO_WALL_CSS_MOD[col];

function escapeXml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

type BrandEntry = { name: string; slug: string };

const plumbingList: BrandEntry[] = [
  { name: "Moen", slug: "moen" },
  { name: "Kohler", slug: "kohler" },
  { name: "Delta", slug: "delta" },
  { name: "Bradford White", slug: "bradford-white" },
  { name: "AO Smith", slug: "ao-smith" },
];

const SUBTITLE_BY_COLLECTION: Partial<Record<ActiveCollectionKey, string>> = {
  plumbing: "CERTIFIED INFRASTRUCTURE MATERIALS & COMPATIBLE SYSTEMS",
  "plumbing-v2": "CERTIFIED INFRASTRUCTURE MATERIALS & COMPATIBLE SYSTEMS",
  roofing: "CERTIFIED INFRASTRUCTURE MATERIALS & COMPATIBLE SYSTEMS",
  "water-damage": "CERTIFIED INFRASTRUCTURE MATERIALS & COMPATIBLE SYSTEMS",
  "siding-services": "CERTIFIED INFRASTRUCTURE MATERIALS & COMPATIBLE SYSTEMS",
  pestcontrol: "PROFESSIONAL EQUIPMENT & NETWORK PARTNERS",
  "community-stewardship-water": "CERTIFIED INFRASTRUCTURE MATERIALS & COMPATIBLE SYSTEMS",
  "community-stewardship-siding": "CERTIFIED INFRASTRUCTURE MATERIALS & COMPATIBLE SYSTEMS",
  "community-stewardship-plumbing": "CERTIFIED INFRASTRUCTURE MATERIALS & COMPATIBLE SYSTEMS",
};

const BRANDS_BY_COLLECTION: Partial<Record<ActiveCollectionKey, BrandEntry[]>> = {
  plumbing: plumbingList,
  "plumbing-v2": plumbingList,
  roofing: [
    { name: "Owens Corning", slug: "owens-corning" },
    { name: "GAF", slug: "gaf" },
    { name: "CertainTeed", slug: "certainteed" },
    { name: "IKO", slug: "iko" },
  ],
  "water-damage": [
    { name: "IICRC (Certified)", slug: "iicrc" },
    { name: "Drieaz", slug: "drieaz" },
    { name: "B-Air", slug: "b-air" },
    { name: "XPOWER", slug: "xpower" },
  ],
  pestcontrol: [
    { name: "Bayer", slug: "bayer" },
    { name: "Syngenta", slug: "syngenta" },
    { name: "BASF", slug: "basf" },
    { name: "Termidor", slug: "termidor" },
  ],
  /** Inline SVG wordmarks — siding vertical (Realtors site-siding, etc.). */
  "siding-services": [
    { name: "James Hardie", slug: "james-hardie" },
    { name: "CertainTeed", slug: "certainteed-exterior" },
    { name: "LP SmartSide", slug: "lp-smartside" },
    { name: "Alside", slug: "alside" },
  ],
  "community-stewardship-water": [
    { name: "IICRC (Certified)", slug: "iicrc" },
    { name: "Drieaz", slug: "drieaz" },
    { name: "B-Air", slug: "b-air" },
    { name: "XPOWER", slug: "xpower" },
  ],
  "community-stewardship-siding": [
    { name: "James Hardie", slug: "james-hardie" },
    { name: "CertainTeed", slug: "certainteed-exterior" },
    { name: "LP SmartSide", slug: "lp-smartside" },
    { name: "Alside", slug: "alside" },
  ],
  "community-stewardship-plumbing": [
    { name: "Moen", slug: "moen" },
    { name: "Kohler", slug: "kohler" },
    { name: "Delta", slug: "delta" },
    { name: "Bradford White", slug: "bradford-white" },
  ],
};

const brands = BRANDS_BY_COLLECTION[col] ?? [];
/** Cap at 4: desktop is strictly 4 columns — never a 4+1 “orphan” row. */
const DISPLAY_BRAND_CAP = 4;
const displayBrands = brands.slice(0, DISPLAY_BRAND_CAP);
const subtitle =
  SUBTITLE_BY_COLLECTION[col] ??
  "CERTIFIED INFRASTRUCTURE MATERIALS & COMPATIBLE SYSTEMS";

/** Tooltip + a11y — matches conversion brief (roofing materials). */
function partnerOfficialTitle(brandName: string): string {
  return `Official Service Standard for ${brandName} Materials`;
}

function fontSizeForName(name: string): number {
  if (name.length > 18) return 9;
  if (name.length > 12) return 10;
  return 12;
}

/**
 * Roofing: typography simulated per brand (no external SVG fetch — native inline markup).
 * Official artwork is trademarked; these are original compositions inspired by common wordmark treatments.
 */
function roofingBrandSvg(slug: string, uid: string, ariaTitle: string): string {
  const t = escapeXml(ariaTitle);
  const baseOpen = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 288 72" role="img" aria-labelledby="${uid}-title" width="288" height="72"><title id="${uid}-title">${t}</title>`;
  const baseClose = `</svg>`;

  if (slug === "owens-corning") {
    return (
      baseOpen +
      `<g fill="currentColor"><text x="144" y="30" text-anchor="middle" font-family="'Segoe Script','Brush Script MT',cursive" font-size="15" font-weight="700" letter-spacing="0.06em">Owens</text><text x="144" y="52" text-anchor="middle" font-family="'Segoe Script','Brush Script MT',cursive" font-size="15" font-weight="700" letter-spacing="0.06em">Corning</text><text x="144" y="66" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" font-weight="800" letter-spacing="0.28em" fill="currentColor" opacity="0.85">TO THE CORE</text></g>` +
      baseClose
    );
  }
  if (slug === "gaf") {
    return (
      baseOpen +
      `<text x="144" y="48" text-anchor="middle" font-family="Arial Black,'Arial Narrow',Arial,sans-serif" font-size="34" font-weight="800" font-style="italic" fill="currentColor" letter-spacing="-0.02em">GAF</text>` +
      baseClose
    );
  }
  if (slug === "certainteed") {
    return (
      baseOpen +
      `<text x="144" y="44" text-anchor="middle" font-family="Georgia,'Times New Roman',Times,serif" font-size="15" font-weight="800" fill="currentColor" letter-spacing="0.02em">CertainTeed</text>` +
      baseClose
    );
  }
  if (slug === "iko") {
    return (
      baseOpen +
      `<text x="144" y="48" text-anchor="middle" font-family="Impact,'Arial Black',sans-serif" font-size="36" font-weight="900" fill="currentColor" letter-spacing="0.14em">IKO</text>` +
      baseClose
    );
  }
  return baseOpen + baseClose;
}

/** Fallback wordmark for non-roofing niches (still inline SVG). */
function genericBrandSvg(b: BrandEntry, index: number): string {
  const uid = `niche-lw-${b.slug}-${index}`;
  const te = escapeXml(b.name);
  const fs = fontSizeForName(b.name);
  const ar = escapeXml(partnerOfficialTitle(b.name));
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 260 56" role="img" aria-labelledby="${uid}-title" width="260" height="56"><title id="${uid}-title">${ar}</title><text x="130" y="34" text-anchor="middle" font-family="Georgia,'Times New Roman',Times,serif" font-size="${fs}" font-weight="700" fill="currentColor" letter-spacing="0.04em">${te}</text></svg>`;
}

function brandSvgMarkup(b: BrandEntry, index: number): string {
  const uid = `niche-lw-${b.slug}-${index}`;
  const ariaTitle = partnerOfficialTitle(b.name);
  if (col === "roofing") {
    return roofingBrandSvg(b.slug, uid, ariaTitle);
  }
  return genericBrandSvg(b, index);
}

/** SEO / caption — invisible on screen, exposed to document semantics. */
function partnerFigcaption(b: BrandEntry): string {
  return `${b.name} certified partner wordmark for compatible systems and materials disclosure on this service area page.`;
}

---

{
  displayBrands.length > 0 ? (
    <section
      class={`niche-logo-wall niche-logo-wall--${nicheLogoWallCssMod}`}
      aria-label="Compatible equipment and materials partners"
    >
      <p class="niche-logo-wall__subtitle">
        <span class="niche-logo-wall__subtitle-row">
          <svg
            class="niche-logo-wall__verified-dot"
            xmlns="http://www.w3.org/2000/svg"
            width="8"
            height="8"
            viewBox="0 0 8 8"
            aria-hidden="true"
            focusable="false"
          >
            <circle cx="4" cy="4" r="3" fill="#16a34a"></circle>
          </svg>
          <span class="niche-logo-wall__subtitle-text">{subtitle}</span>
        </span>
      </p>
      <ul class="niche-logo-wall__grid">
        {displayBrands.map((b, i) => (
          <li class="niche-logo-wall__cell">
            <figure class="niche-logo-wall__figure" aria-labelledby={`niche-logo-wall-cap-${i}`}>
              <div class="niche-logo-wall__card">
                <div class="niche-logo-wall__logo-slot" data-brand-slug={b.slug} aria-hidden="true">
                  <span class="niche-logo-wall__svg-wrap" set:html={brandSvgMarkup(b, i)} />
                </div>
              </div>
              <figcaption id={`niche-logo-wall-cap-${i}`} class="niche-logo-wall__caption">
                {partnerFigcaption(b)}
              </figcaption>
            </figure>
          </li>
        ))}
      </ul>
    </section>
  ) : null
}

<style>
  /*
   * Tailwind token equivalents (project has no @tailwind — semantic parity only):
   * gray-100 #f3f4f6 | gray-50 #f9fafb | max-w-[100px] | h-16 4rem | tracking-widest 0.1em
   */
  .niche-logo-wall {
    margin: 0.75rem 0 2.5rem; /* mb-10 */
    padding: 0.75rem 0;
    border-top: 1px solid #f3f4f6;
    border-bottom: 1px solid rgba(243, 244, 246, 0.3); /* gray-100 @ ~30% — credit pulse */
  }
  .niche-logo-wall__subtitle {
    margin: 0 0 0.65rem;
    padding: 0 0.5rem;
    font-size: calc(0.62rem - 1px);
    font-weight: 700;
    text-transform: uppercase;
    color: #94a3b8;
    line-height: 1.45;
    text-align: center;
    letter-spacing: 0.1em; /* tracking-widest */
  }
  .niche-logo-wall__subtitle-row {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    flex-wrap: wrap;
    max-width: 100%;
  }
  .niche-logo-wall__verified-dot {
    flex-shrink: 0;
    display: block;
  }
  .niche-logo-wall__subtitle-text {
    text-align: center;
  }
  .niche-logo-wall__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    align-items: stretch;
    justify-items: stretch;
  }
  /* Mobile: last row single item — centered, no empty “ghost” cells */
  .niche-logo-wall__cell:last-child:nth-child(odd):not(:only-child) {
    grid-column: 1 / -1;
    justify-self: center;
    width: calc((100% - 0.75rem) / 2);
    max-width: calc((100% - 0.75rem) / 2);
  }
  .niche-logo-wall__cell:only-child {
    grid-column: 1 / -1;
    justify-self: center;
    width: calc((100% - 0.75rem) / 2);
    max-width: calc((100% - 0.75rem) / 2);
  }
  @media (min-width: 768px) {
    /* Desktop: exactly four logical slots per row; <4 logos stay centered as a group */
    .niche-logo-wall__grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: stretch;
      gap: 0.75rem;
    }
    .niche-logo-wall__cell {
      flex: 0 1 calc(25% - 0.5625rem);
      max-width: calc(25% - 0.5625rem);
      width: auto;
      grid-column: unset;
      justify-self: auto;
    }
    .niche-logo-wall__cell:last-child:nth-child(odd):not(:only-child),
    .niche-logo-wall__cell:only-child {
      grid-column: unset;
      justify-self: auto;
      width: auto;
      flex: 0 1 calc(25% - 0.5625rem);
      max-width: calc(25% - 0.5625rem);
    }
  }
  .niche-logo-wall__cell {
    margin: 0;
    padding: 0;
    display: flex;
    align-items: stretch;
    justify-content: center;
    min-height: 0;
    overflow: visible;
  }
  .niche-logo-wall__figure {
    margin: 0;
    padding: 0;
    width: 100%;
    flex: 1;
    min-height: 5rem;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    position: relative;
  }
  .niche-logo-wall__caption {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .niche-logo-wall--roofing {
    margin-top: calc(0.75rem + 1px);
    padding-top: calc(0.75rem + 2px);
    border-top-color: #eef1f6;
  }
  .niche-logo-wall--plumbing {
    margin-top: calc(0.75rem + 2px);
    padding-top: calc(0.75rem + 1px);
    border-top-color: #edf0f5;
  }
  .niche-logo-wall--pestcontrol {
    margin-top: calc(0.75rem + 3px);
    padding-top: 0.75rem;
    border-top-color: #eceff4;
  }
  .niche-logo-wall--water-damage {
    margin-top: 0.75rem;
    padding-top: calc(0.75rem + 3px);
    border-top-color: #eaeef3;
  }
  .niche-logo-wall--exterior-clad-trade {
    margin-top: calc(0.75rem + 4px);
    padding-top: calc(0.75rem + 1px);
    border-top-color: #e9edf2;
  }
  .niche-logo-wall--plumbing-v2 {
    margin-top: calc(0.75rem + 1px);
    padding-top: calc(0.75rem + 4px);
    border-top-color: #e8ecf1;
  }
  .niche-logo-wall__card {
    width: 100%;
    flex: 1;
    min-height: 5rem;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.55rem;
    border-radius: 0.375rem; /* rounded-md */
    border: 1px solid #e2e8f0; /* slate-200 — 比 slate-100 更清晰 */
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    /* shadow-sm：卡片轻微离地 */
    box-shadow: 0 1px 2px 0 rgb(15 23 42 / 0.05);
    transform: scale(1);
    transform-origin: center center;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }
  .niche-logo-wall__cell:hover .niche-logo-wall__card,
  .niche-logo-wall__cell:focus-within .niche-logo-wall__card {
    border-color: #cbd5e1; /* slate-300 */
    box-shadow:
      0 1px 2px 0 rgb(15 23 42 / 0.05),
      0 4px 14px -3px rgb(15 23 42 / 0.1);
    transform: scale(1.05);
  }
  /* Per-brand “seal” dot (CSS ::before — no extra DOM) */
  .niche-logo-wall__logo-slot {
    --partner-dot: #64748b;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3rem;
    padding-left: 0.6rem;
    box-sizing: border-box;
  }
  /* 左侧微型品牌徽标：色块 + 高光 + 细环，近似「认证 seal」 */
  .niche-logo-wall__logo-slot::before {
    content: "";
    position: absolute;
    left: 0.04rem;
    top: 50%;
    width: 0.5rem;
    height: 0.5rem;
    margin-top: -0.25rem;
    border-radius: 50%;
    background:
      radial-gradient(circle at 30% 28%, rgba(255, 255, 255, 0.88) 0%, rgba(255, 255, 255, 0.88) 24%, transparent 26%),
      var(--partner-dot);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.95),
      0 0 0 2px rgba(15, 23, 42, 0.07),
      0 1px 2px rgb(15 23 42 / 0.12);
    flex-shrink: 0;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="moen"] {
    --partner-dot: #2563eb;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="kohler"] {
    --partner-dot: #0f172a;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="delta"] {
    --partner-dot: #0369a1;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="bradford-white"] {
    --partner-dot: #b45309;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="ao-smith"] {
    --partner-dot: #1d4ed8;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="owens-corning"] {
    --partner-dot: #ea580c;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="gaf"] {
    --partner-dot: #15803d;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="certainteed"] {
    --partner-dot: #1e40af;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="iko"] {
    --partner-dot: #dc2626;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="iicrc"] {
    --partner-dot: #0f766e;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="drieaz"] {
    --partner-dot: #2563eb;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="b-air"] {
    --partner-dot: #7c3aed;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="xpower"] {
    --partner-dot: #ea580c;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="bayer"] {
    --partner-dot: #0050b4;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="syngenta"] {
    --partner-dot: #16a34a;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="basf"] {
    --partner-dot: #0046ad;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="termidor"] {
    --partner-dot: #92400e;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="james-hardie"] {
    --partner-dot: #7f1d1d;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="certainteed-exterior"] {
    --partner-dot: #1e3a8a;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="lp-smartside"] {
    --partner-dot: #3f6212;
  }
  .niche-logo-wall__logo-slot[data-brand-slug="alside"] {
    --partner-dot: #0284c7;
  }
  .niche-logo-wall__svg-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3rem;
    color: #0f172a;
    filter: grayscale(0.8) contrast(1.2);
    opacity: 0.95;
    transition:
      filter 0.2s ease,
      opacity 0.2s ease;
  }
  .niche-logo-wall__cell:hover .niche-logo-wall__svg-wrap,
  .niche-logo-wall__cell:focus-within .niche-logo-wall__svg-wrap {
    filter: grayscale(0) contrast(1.05);
    opacity: 1;
  }
  .niche-logo-wall__svg-wrap :global(svg) {
    width: 100%;
    max-width: 100%;
    height: 3rem;
    min-height: 3rem;
    max-height: 3rem;
    object-fit: contain;
    display: block;
  }
  /* Industrial “engraved plate” typography for all inline wordmarks */
  .niche-logo-wall__svg-wrap :global(svg text) {
    font-family: Georgia, "Times New Roman", Times, serif !important;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  @media (prefers-reduced-motion: reduce) {
    .niche-logo-wall__card {
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .niche-logo-wall__cell:hover .niche-logo-wall__card,
    .niche-logo-wall__cell:focus-within .niche-logo-wall__card {
      transform: none;
    }
  }
</style>
