---
import { getCollection, render } from "astro:content";
import Footer from "../components/Footer.astro";
import FAQSection from "../components/FAQSection.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import LiveDispatchFeed from "../components/LiveDispatchFeed.astro";
import MarketDataView from "../components/MarketDataView.astro";
import RelatedCities from "../components/RelatedCities.astro";
import ValueProtectionCalculator from "../components/ValueProtectionCalculator.astro";
import OfficialRiskNodeHeader from "../components/OfficialRiskNodeHeader.astro";
import TrustBar from "../components/TrustBar.astro";
import NationalDispatchDisclaimer from "../components/NationalDispatchDisclaimer.astro";
import NichePartnerLogos from "../components/NichePartnerLogos.astro";
import DispatchCommandBar from "../components/DispatchCommandBar.astro";
import { ACTIVE_COLLECTION, type ActiveCollectionKey } from "../active-collection";
import {
  BRAND_CONFIG,
  PUBLIC_NICHE_LABEL,
  canonicalPageUrl,
  getNicheLabelForSeed,
  internalPath,
  siteConfig,
} from "../site-config";
import {
  REALTORS_AT_THE_BEACH_WATER_DAMAGE,
  matchesRealtorsAtTheBeachWaterDamage,
} from "../domain-templates/realtorsatthebeach.com-water-damage";
import {
  REALTORS_AT_THE_BEACH_PLUMBING_V2,
} from "../domain-templates/realtorsatthebeach.com-plumbing-v2";
import { buildBreadcrumbListSchema, buildSlugPageBreadcrumbItems } from "../lib/breadcrumb-schema";
import { buildMicroGeoFingerprintLine, getStatePhysicalEnvironmentFact } from "../lib/geo-facts";
import { pickTwoGeoDescriptors } from "../lib/geo-descriptor-lexicon";
import { pickTwoMetaAnalysisLines } from "../lib/meta-analysis-lexicon";
import {
  buildFaqSchema,
  buildLocalBusinessSchema,
  buildNewtownFellowshipLocalBusinessSchema,
  buildPhysicalInfrastructureDatasetSchema,
  buildRegionalServiceAreaSchema,
} from "../lib/seo";
import { buildFaqSectionItems } from "../lib/faq-section-model";
import { pickTwoEngineeringNoticeClauses } from "../lib/engineering-notice-lexicon";
import { buildContextAwareSummary } from "../lib/context-aware-summary";
import { resolvePageLocation } from "../lib/location";
import {
  buildRockwellMaineEntityGraph,
  matchesRockwellMaine,
} from "../domain-templates/rockwell-maine-entity";
import { matchesNewtownFellowshipSite } from "../domain-templates/newtown-fellowship-site";
import {
  STEWARDSHIP_HUB_KEYS,
  stewardshipDevHubMergeEnabled,
} from "../lib/stewardship-dev-hub-paths";

/** Physical-value tier: deterministic title/H1 (no stableHash) when home value clears bar. */
const HIGH_VALUE_USD_TRIGGER = 300_000;

export async function getStaticPaths() {
  if (stewardshipDevHubMergeEnabled()) {
    const out: {
      params: { slug: string };
      props: { stewardshipPageCollection: ActiveCollectionKey };
    }[] = [];
    for (const col of STEWARDSHIP_HUB_KEYS) {
      const posts = await getCollection(col);
      for (const post of posts) {
        const slug = (post.slug ?? post.id ?? "").replace(/\.(md|mdx)$/i, "");
        out.push({ params: { slug }, props: { stewardshipPageCollection: col } });
      }
    }
    return out;
  }
  const posts = await getCollection(ACTIVE_COLLECTION);
  return posts.map((post) => ({
    params: { slug: (post.slug ?? post.id ?? "").replace(/\.(md|mdx)$/i, "") },
  }));
}

const { slug } = Astro.params;
const routeProps = Astro.props as { stewardshipPageCollection?: ActiveCollectionKey };
/** 本 URL 对应的内容集合（dev 三合一 hub 时由 getStaticPaths props 注入，否则等于构建期 ACTIVE_COLLECTION）。 */
const PAGE_COLLECTION: ActiveCollectionKey = routeProps.stewardshipPageCollection ?? ACTIVE_COLLECTION;

/** Monorepo: water-damage vertical (sync with `sites/site-water-damage`). */
const isWaterDamageHub = PAGE_COLLECTION === "water-damage";
/** Monorepo: plumbing vertical (sync with `sites/site-plumbing`). */
const isPlumbingHub = PAGE_COLLECTION === "plumbing";
/** Rockwell roofing vertical (`sites/site-roofing` terrain-notice funnel). */
const isRoofingHub = PAGE_COLLECTION === "roofing";
/** Community stewardship verticals (separate static Pages children; MD from `main.go`). */
const isCommunityStewardshipWater = PAGE_COLLECTION === "community-stewardship-water";
const isCommunityStewardshipSiding = PAGE_COLLECTION === "community-stewardship-siding";
const isCommunityStewardshipPlumbing = PAGE_COLLECTION === "community-stewardship-plumbing";
const isCommunityStewardshipHub =
  isCommunityStewardshipWater || isCommunityStewardshipSiding || isCommunityStewardshipPlumbing;
const heroAsWater = isWaterDamageHub || isCommunityStewardshipWater;
const heroAsPlumbing = isPlumbingHub || isCommunityStewardshipPlumbing;

const posts = await getCollection(PAGE_COLLECTION);
const entrySlugParam = (slug ?? "").replace(/\.(md|mdx)$/i, "");
const entry =
  posts.find((p) => (p.slug ?? p.id ?? "").replace(/\.(md|mdx)$/i, "") === entrySlugParam) ?? null;
if (!entry) {
  const hubHint = stewardshipDevHubMergeEnabled()
    ? ""
    : ` 也可在 <strong>dev</strong> 下使用 <code>DEV_COMMUNITY_STEWARDSHIP_HUB=1</code> 并执行 <code>npm run dev:community-stewardship-hub:fast</code>，即可在同一端口打开 water / siding / plumbing 三个 slug。`;
  const hint = `当前构建集合为 <code>${ACTIVE_COLLECTION}</code>，未找到 slug「${entrySlugParam}」。` +
    `若这是 community-stewardship 详情，请先停掉 dev 再运行：` +
    `<code>npm run dev:community-stewardship-water:fast</code>（或 siding / plumbing 对应脚本），再刷新本 URL。` +
    hubHint;
  return new Response(
    `<!DOCTYPE html><html lang="zh-Hans"><head><meta charset="utf-8"><title>404 — 集合与 slug 不匹配</title></head>` +
      `<body style="font-family:system-ui,sans-serif;padding:1.5rem;max-width:42rem;line-height:1.5">` +
      `<h1>404 — 无此内容条目</h1><p>${hint}</p>` +
      `<p><a href="${import.meta.env.BASE_URL ?? "/"}">返回首页</a></p></body></html>`,
    {
      status: 404,
      headers: { "content-type": "text/html; charset=utf-8" },
    },
  );
}
const { Content } = await render(entry);
const post = entry;
/** Single source of truth for this URL — canonical must never follow raw params alone. */
const entrySlug = (post.slug ?? post.id ?? "").replace(/\.(md|mdx)$/i, "");
const pageUrl = canonicalPageUrl(entrySlug);
const pageNicheLabel = getNicheLabelForSeed(entrySlug);
const isRockwellMaine = matchesRockwellMaine({ domainOrUrl: siteConfig.canonicalOrigin });
const isNewtownFellowshipSite = matchesNewtownFellowshipSite({
  canonicalOrigin: siteConfig.canonicalOrigin,
  siteUrl: siteConfig.siteUrl,
});
const pageLocation = resolvePageLocation({
  collection: PAGE_COLLECTION,
  title: post.data.title,
  slug: entrySlug,
  fmCity: post.data.city,
  fmState: post.data.state,
  fmZip: post.data.zipCode,
});
function titleCase(s: string) {
  return s
    .split(/\s+/g)
    .filter(Boolean)
    .map((w) => w.slice(0, 1).toUpperCase() + w.slice(1))
    .join(" ");
}
function cityFromSlug(slugText: string) {
  const m = slugText.match(/^(.*)-([a-z]{2})-(\d{5})$/i);
  if (!m) return null;
  let prefixAndCity = m[1]!;
  const pfx = `${String(PAGE_COLLECTION)}-`.toLowerCase();
  if (prefixAndCity.toLowerCase().startsWith(pfx)) {
    prefixAndCity = prefixAndCity.slice(pfx.length);
  }
  const city = prefixAndCity.split("-").filter(Boolean).join(" ").trim();
  return city ? titleCase(city) : null;
}
const pageCity = cityFromSlug(entrySlug);
const trustDispatchPlace = pageCity?.trim() ? pageCity.trim() : "Area";
const desktopDispatchZip =
  String(pageLocation?.zip ?? post.data.zipCode ?? "")
    .replace(/\D/g, "")
    .slice(0, 5) || "00000";
const stateCodeFromSlug = (() => {
  const m = entrySlug.match(/-([a-z]{2})-\d{5}$/i);
  return m ? m[1]!.toUpperCase() : null;
})();
/** US State service-area + FixitGrid provider; `url` = this page canonical (per-city, no cross-city bleed). */
const regionalServiceSchema =
  !isNewtownFellowshipSite && stateCodeFromSlug != null
    ? buildRegionalServiceAreaSchema({ stateCode: stateCodeFromSlug, pageUrl })
    : null;
/** Slug tail `…-{ST}-{ZIP}` — same source as audit-node ID / Dataset zip. */
const slugGeoTailForPhysical = (() => {
  const m = entrySlug.match(/-([a-z]{2})-(\d{5})$/i);
  return m ? { state: m[1]!.toUpperCase(), zip: m[2]! } : null;
})();
const physicalDatasetCityLabel =
  pageCity ??
  ((typeof post.data.city === "string" ? post.data.city.replace(/\s+/g, " ").trim() : "") || "Local");
const physicalInfrastructureDatasetSchema =
  !isNewtownFellowshipSite && slugGeoTailForPhysical != null
    ? buildPhysicalInfrastructureDatasetSchema({
        cityDisplay: physicalDatasetCityLabel,
        zip5: slugGeoTailForPhysical.zip,
        pageUrl,
      })
    : null;
const auditNodeFingerprintVersion =
  String(post.data.templateVersion ?? "1")
    .trim()
    .replace(/[^\w.-]/g, "") || "1";
// Action 1: footer random internal link from backup pool (state index + random city)
const backupCandidates: { href: string; label: string }[] = [];
if (stateCodeFromSlug) {
  backupCandidates.push({
    href: internalPath(stateCodeFromSlug.toLowerCase()),
    label: `Browse ${pageNicheLabel} in ${stateCodeFromSlug}`,
  });
}
const other = posts.filter((p) => (p.slug ?? p.id ?? "").replace(/\.(md|mdx)$/i, "") !== entrySlug);
if (other.length > 0) {
  const pick = other[Math.floor(Math.random() * other.length)]!;
  const pickSlug = (pick.slug ?? pick.id ?? "").replace(/\.(md|mdx)$/i, "");
  backupCandidates.push({
    href: internalPath(pickSlug),
    label: `Another ${pageNicheLabel} page`,
  });
}
const footerExtraLink =
  backupCandidates.length > 0 ? backupCandidates[Math.floor(Math.random() * backupCandidates.length)]! : null;

type DispatchFeedRecord = {
  city: string;
  state: string;
  offset: number;
  tag: "[NODE ACTIVE]" | "[DISPATCH CONFIRMED]";
};

function shuffledDispatch<T>(arr: T[]): T[] {
  const out = [...arr];
  for (let i = out.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [out[i], out[j]] = [out[j]!, out[i]!];
  }
  return out;
}

function cityLabelFromEntry(entry: (typeof posts)[number]): string {
  const c = entry.data.city?.trim();
  if (c) return titleCase(c);
  const slugText = (entry.slug ?? entry.id ?? "").replace(/\.(md|mdx)$/i, "");
  return cityFromSlug(slugText) ?? "Unknown City";
}

/** Water-damage city pages: optional ledger (parity with `sites/site-water-damage` state hub). */
const slugDispatchFeedRecords: DispatchFeedRecord[] = (() => {
  if ((!isWaterDamageHub && !isCommunityStewardshipWater) || !stateCodeFromSlug) return [];
  const st = stateCodeFromSlug.toUpperCase();
  const sameState = posts.filter((p) => {
    const s = (p.slug ?? p.id ?? "").replace(/\.(md|mdx)$/i, "");
    const m = s.match(/-([a-z]{2})-\d{5}$/i);
    return m && m[1]!.toUpperCase() === st && s !== entrySlug;
  });
  if (sameState.length === 0) return [];
  return shuffledDispatch(sameState.map((p) => ({ city: cityLabelFromEntry(p), state: st })))
    .slice(0, 8)
    .map((item, idx) => ({
      ...item,
      offset: 5 + Math.floor(Math.random() * 51),
      tag: (idx % 2 === 0 ? "[NODE ACTIVE]" : "[DISPATCH CONFIRMED]") as DispatchFeedRecord["tag"],
    }));
})();

function stableHash(input: string) {
  let h = 2166136261;
  for (let i = 0; i < input.length; i++) {
    h ^= input.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}
function formatZillowUsdShort(usd: number): string {
  if (!Number.isFinite(usd) || usd <= 0) return "";
  if (usd >= 1_000_000) {
    const m = usd / 1_000_000;
    const s =
      m >= 10
        ? String(Math.round(m))
        : String(Math.round(m * 100) / 100).replace(new RegExp("\\.?0+$"), "");
    return `$${s}M`;
  }
  const k = usd / 1000;
  if (k < 10) return `$${Math.round(usd).toLocaleString("en-US")}`;
  const roundedK = Math.round(k * 10) / 10;
  const sk = Number.isInteger(roundedK) ? String(roundedK) : roundedK.toFixed(1).replace(/\.0$/, "");
  return `$${sk}K`;
}
function clipMetaDescription(text: string, max = 158): string {
  const t = text.trim();
  if (t.length <= max) return t;
  return `${t.slice(0, max - 1).trimEnd().replace(/[,;\s]+$/, "")}…`;
}
function stateLabelForBait(stateCode: string, stateFromFm: string | undefined): string {
  const fm = (stateFromFm ?? "").trim();
  if (fm.length > 2) return fm;
  return stateCode;
}

const WATER_TITLE_BRAND_SUFFIX = ` | ${BRAND_CONFIG.rockwell.name}`;
function withWaterTitleBrand(raw: string): string {
  const t = raw.trim();
  const tail = BRAND_CONFIG.rockwell.name;
  if (t.endsWith(tail)) return t;
  return `${t}${WATER_TITLE_BRAND_SUFFIX}`;
}

const zRaw = post.data.zillowHomeValueUsd;
const zUsd =
  typeof zRaw === "number" && Number.isFinite(zRaw) && zRaw > 0 ? zRaw : null;
const zLabel = zUsd != null ? formatZillowUsdShort(zUsd) : null;
const zLabelExact =
  zUsd != null
    ? new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
        maximumFractionDigits: 0,
      }).format(zUsd)
    : null;
const baitPickRaw = stableHash(`${PAGE_COLLECTION}|${entrySlug}|bait2`) % 3;
const isFinancialPressureMode =
  zUsd != null &&
  zUsd >= HIGH_VALUE_USD_TRIGGER &&
  zLabelExact != null &&
  pageCity != null;

/** Title brand tail (short SERP); full Rockwell name lives in meta/footer — keep ≤60 total. */
const SERP_TITLE_BRAND = "FixitGrid";

/**
 * Service clauses for `[zLabel] Asset Defense: [City] [Service] | FixitGrid` — longest first.
 * Compression protocol: truncate Service only; never truncate zLabel or City.
 */
const SERP_ASSET_DEFENSE_SERVICES: Record<ActiveCollectionKey, readonly string[]> = {
  roofing: ["Emergency Roofing (Rapid Response)", "Emergency Roofing", "Roofing"],
  plumbing: ["Emergency Plumbing (Rapid Response)", "Emergency Plumbing", "Plumbing"],
  pestcontrol: ["Emergency Pest Control (Rapid)", "Emergency Pest Control", "Pest Control"],
  "water-damage": ["Emergency Water Damage (Rapid)", "Emergency Water Damage", "Water Damage"],
  "siding-services": ["Emergency Siding (Rapid Response)", "Emergency Siding", "Siding"],
  "plumbing-v2": ["Emergency Plumbing (Rapid Response)", "Emergency Plumbing", "Plumbing"],
  "community-stewardship-water": [
    "Emergency Water Stewardship (Rapid)",
    "Water Stewardship",
    "Water Systems",
  ],
  "community-stewardship-siding": [
    "Emergency Exterior Stewardship (Rapid)",
    "Exterior Stewardship",
    "Siding",
  ],
  "community-stewardship-plumbing": [
    "Emergency Plumbing Stewardship (Rapid)",
    "Plumbing Stewardship",
    "Plumbing",
  ],
};

function clipAssetDefenseTitle60(
  zLabelForTitle: string | null,
  cityRaw: string | null,
  serviceCandidates: string[],
): string {
  const tail = ` | ${SERP_TITLE_BRAND}`;
  const assetPrefix = zLabelForTitle ? `${zLabelForTitle} Asset Defense: ` : `Asset Defense: `;
  const city = (cityRaw ?? "Local").replace(/\s+/g, " ").trim();

  const assemble = (svc: string) => {
    const s = svc.replace(/\s+/g, " ").trim();
    const mid = s ? `${city} ${s}` : city;
    return `${assetPrefix}${mid}${tail}`;
  };

  const seen = new Set<string>();
  const pool: string[] = [];
  for (const c of serviceCandidates) {
    const k = c.replace(/\s+/g, " ").trim();
    if (!k || seen.has(k)) continue;
    seen.add(k);
    pool.push(k);
  }
  pool.sort((a, b) => b.length - a.length);

  for (const svc of pool) {
    const t = assemble(svc);
    if (t.length <= 60) return t;
  }

  let svc = pool[pool.length - 1] ?? "Service";
  svc = svc.trim();
  while (svc.length > 0 && assemble(svc).length > 60) {
    svc = svc.slice(0, -1).replace(/[\s(/,.-]+$/, "").trimEnd();
  }
  let out = assemble(svc);
  if (out.length <= 60) return out;

  out = assemble("");
  if (out.length <= 60) return out;

  return assemble("").slice(0, 60);
}

function buildAssetDefenseSerpTitle(): string {
  const base = [...SERP_ASSET_DEFENSE_SERVICES[PAGE_COLLECTION]];
  if (isFinancialPressureMode) {
    const short = base[base.length - 1] ?? "Service";
    base.unshift(`Critical ${short}`);
  }
  const r = baitPickRaw % Math.max(1, base.length);
  const rotated = [...base.slice(r), ...base.slice(0, r)];
  return clipAssetDefenseTitle60(zLabel, pageCity, rotated);
}

const NEWTOWN_OUTREACH_SERVICE_LABEL: Record<ActiveCollectionKey, string> = {
  roofing: "Roofing",
  plumbing: "Plumbing",
  pestcontrol: "Pest Control",
  "water-damage": "Water Recovery",
  "siding-services": "Exterior",
  "plumbing-v2": "Plumbing",
  "community-stewardship-water": "Water Systems",
  "community-stewardship-siding": "Exterior",
  "community-stewardship-plumbing": "Plumbing",
};

function buildNewtownFellowshipSerpTitle(cityRaw: string | null, collection: ActiveCollectionKey): string {
  const city = (cityRaw ?? "Local").replace(/\s+/g, " ").trim();
  const svc = NEWTOWN_OUTREACH_SERVICE_LABEL[collection] ?? "Community";
  return `${city} Community Outreach: ${svc} Stewardship & Support | Newtown Fellowship`;
}

const waterH1Lead = pageCity
  ? `IICRC Certified ${pageCity} Response — Direct Billing to Insurance — `
  : `IICRC Certified Response — Direct Billing to Insurance — `;

const waterVisualLine = pageCity
  ? `Urgent Notice: Your ${pageCity} property terrain data indicates high-risk saturation levels. Immediate structural drying is required to prevent mold colonization.`
  : `Urgent Notice: Your property terrain data indicates high-risk saturation levels. Immediate structural drying is required to prevent mold colonization.`;

const PINTEREST_META_CTA = `Search "FixitGrid Local Dispatch Network" on Google.`;

function waterMetaLead(): string {
  if (pageCity) {
    return `Don't pay for flood damage out of pocket. We offer direct insurance billing for ${pageCity} residents and immediate water extraction. Verified IICRC dispatch available 24/7.`;
  }
  if (stateCodeFromSlug) {
    return `Don't pay for flood damage out of pocket. We offer direct insurance billing for ${stateCodeFromSlug} residents and immediate water extraction. Verified IICRC dispatch available 24/7.`;
  }
  return `Don't pay for flood damage out of pocket. We offer direct insurance billing and immediate water extraction. Verified IICRC dispatch available 24/7.`;
}

const h1ComplianceLead = "$0 Dispatch Fee · Upfront Pricing — ";

const plumbingVisualLine = pageCity
  ? `Our ${pageCity} dispatch node ensures state-compliant pricing. Cross-referenced with USGS infrastructure risk scores to prevent plumbing scams.`
  : `Our dispatch node ensures state-compliant pricing. Cross-referenced with USGS infrastructure risk scores to prevent plumbing scams.`;

const roofTerrainNotice = isRoofingHub
  ? pageCity
    ? `NOTICE: Your ${pageCity} property has a specific terrain-risk profile. Delaying repair could impact insurance eligibility.`
    : null
  : null;

const PINTEREST_META_CTA_PLUMBING = `Search "FixitGrid Local Dispatch Network" on Google.`;

function plumbingMetaLead(): string {
  if (pageCity) {
    return `Stop overpaying. Get upfront pricing and verified plumbing for ${pageCity} residents. No hidden dispatch fees. Emergency dispatch available 24/7.`;
  }
  if (stateCodeFromSlug) {
    return `Stop overpaying. Get upfront pricing and verified plumbing for ${stateCodeFromSlug} residents. No hidden dispatch fees. Emergency dispatch available 24/7.`;
  }
  return `Stop overpaying. Get upfront pricing and verified plumbing. No hidden dispatch fees. Emergency dispatch available 24/7.`;
}

/** `<title>`: Rockwell 用 Asset Defense 压缩协议；Newtown Fellowship 禁用该语义轴。 */
const pageTitle = isNewtownFellowshipSite
  ? buildNewtownFellowshipSerpTitle(pageCity, PAGE_COLLECTION)
  : buildAssetDefenseSerpTitle();

/** Visible `<h1>` fallback */
const pageH1Plain = heroAsWater
  ? zLabelExact && pageCity
    ? `${waterH1Lead}${pageCity} Emergency Dispatch - Protecting your ${zLabelExact} Asset`
    : zLabelExact
      ? `${waterH1Lead}Emergency Dispatch - Protecting your ${zLabelExact} Asset`
      : pageCity
        ? `${waterH1Lead}${pageCity} Emergency Dispatch - Protecting your property`
        : `${waterH1Lead}${post.data.title}`
  : heroAsPlumbing
    ? zLabelExact && pageCity
      ? `${h1ComplianceLead}${pageCity} Emergency Dispatch - Protecting your ${zLabelExact} Asset`
      : zLabelExact
        ? `${h1ComplianceLead}Emergency Dispatch - Protecting your ${zLabelExact} Asset`
        : pageCity
          ? `${h1ComplianceLead}${pageCity} Emergency Dispatch - Protecting your property`
          : `${h1ComplianceLead}${post.data.title}`
    : zLabelExact && pageCity
      ? `${pageCity} infrastructure stewardship — ${zLabelExact} median context`
      : zLabelExact
        ? `Infrastructure stewardship — ${zLabelExact} median context`
        : pageCity
          ? `${pageCity} infrastructure stewardship — protecting your property systems`
          : post.data.title;

const newtownStewardshipH1Line = `Zion Residential Stewardship - Empowering ${(pageCity ?? "Local").replace(/\s+/g, " ").trim()} Neighbors`;
const newtownHeroSubline =
  "Faith-rooted neighborhood education and voluntary housing stewardship — informational content only.";

const pageMetaDescriptionDefault = heroAsWater
  ? clipMetaDescription(
      (() => {
        const lead = `${waterMetaLead()} ${PINTEREST_META_CTA} `;
        const base = post.data.description;
        const tail = (() => {
          if (zLabelExact && !base.includes(zLabelExact)) {
            if (pageCity && stateCodeFromSlug) {
              return `${base} Benchmark median home value near ${zLabelExact} (${pageCity} ${stateCodeFromSlug} market context).`;
            }
            return `${base} Benchmark median home value near ${zLabelExact}.`;
          }
          return base;
        })();
        return `${lead}${tail}`;
      })(),
    )
  : heroAsPlumbing
    ? clipMetaDescription(
        (() => {
          const lead = `${plumbingMetaLead()} ${PINTEREST_META_CTA_PLUMBING} `;
          const base = post.data.description;
          const tail = (() => {
            if (zLabelExact && !base.includes(zLabelExact)) {
              if (pageCity && stateCodeFromSlug) {
                return `${base} Benchmark median home value near ${zLabelExact} (${pageCity} ${stateCodeFromSlug} market context).`;
              }
              return `${base} Benchmark median home value near ${zLabelExact}.`;
            }
            return base;
          })();
          return `${lead}${tail}`;
        })(),
      )
    : clipMetaDescription(
        (() => {
          const base = post.data.description;
          if (zLabelExact && !base.includes(zLabelExact)) {
            if (pageCity && stateCodeFromSlug) {
              return `${base} Benchmark median home value near ${zLabelExact} (${pageCity} ${stateCodeFromSlug} market context).`;
            }
            return `${base} Benchmark median home value near ${zLabelExact}.`;
          }
          return base;
        })(),
      );

const pageMetaDescription = heroAsWater
  ? isFinancialPressureMode
    ? clipMetaDescription(
        `${waterMetaLead()} ${PINTEREST_META_CTA} Benchmark: ${zLabelExact}. Flood risk coordination and documented intake.`,
      )
    : pageMetaDescriptionDefault
  : heroAsPlumbing
    ? isFinancialPressureMode
      ? clipMetaDescription(
          `${plumbingMetaLead()} ${PINTEREST_META_CTA_PLUMBING} Benchmark: ${zLabelExact}. Emergency plumbing audit coordination and documented intake.`,
        )
      : pageMetaDescriptionDefault
    : isFinancialPressureMode
      ? clipMetaDescription(
