      [class$="--faq"] p {
        margin: 0.55rem 0 0.1rem;
        color: #334155;
      }
      .geo-brief,
      [class$="--geo-brief"] {
        margin-top: 1.75rem;
        border-top: 1px solid #e2e8f0;
        padding-top: 1rem;
      }
      .geo-brief h2,
      [class$="--geo-brief"] h2 {
        margin: 0 0 0.5rem;
      }
      .geo-brief p,
      [class$="--geo-brief"] p {
        margin: 0.4rem 0;
        color: #334155;
      }
      .geo-brief-descriptor,
      [class$="--geo-brief"] .geo-brief-descriptor {
        margin: 0.45rem 0 0;
        font-size: 0.82rem;
        line-height: 1.45;
        color: #475569;
      }
      .micro-geo-fingerprint-line {
        margin: 1.25rem 0 0;
        padding-top: 0.75rem;
        border-top: 1px solid #e2e8f0;
        font-size: 0.75rem;
        line-height: 1.45;
        color: #64748b;
      }
      .meta-analysis-wrap {
        margin: 0 0 0.85rem;
        padding: 0.65rem 0.75rem;
        border-radius: 8px;
        border: 1px dashed #cbd5e1;
        background: #fafbfc;
      }
      .meta-analysis-line {
        margin: 0.35rem 0 0;
        font-size: 0.8rem;
        line-height: 1.45;
        color: #475569;
      }
      .meta-analysis-line:first-child {
        margin-top: 0;
      }
    </style>
    <!-- Markdown 由 <Content /> 注入，子节点无本页 scoped 属性；用 is:global + 固定 id，避免 dev/HMR 下偶发“正文像空白”（与 build 静态 HTML 一致） -->
    <style is:global>
      [id$="article-md-body"] {
        max-width: 100%;
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      /* Dynamic Engineering Notice (SSR); hide generator first paragraph still in markdown */
      [id$="article-md-body"] .engineering-notice-dynamic {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
          monospace;
        font-size: 0.92rem;
        line-height: 1.45;
        background: #0b1220;
        color: #e2e8f0;
        border: 1px solid rgba(226, 232, 240, 0.18);
        border-radius: 10px;
        padding: 0.75rem 0.9rem;
        margin: 0 0 1rem;
      }
      [id$="article-md-body"] .engineering-notice-dynamic strong {
        color: #f8fafc;
        font-weight: 700;
      }
      [id$="article-md-body"] .engineering-notice-dynamic + p {
        display: none !important;
      }
      [id$="article-md-body"] p {
        display: block;
        margin: 0.65rem 0;
        color: #334155;
        line-height: 1.55;
      }
      [id$="article-md-body"] strong {
        color: #0f172a;
      }
      .h1-zmoney {
        color: #b91c1c;
        font-weight: 800;
        font-size: 1.1em;
        text-decoration: underline;
      }
    </style>
    <style is:global set:html={layoutSkinCss} />
  </head>
  <body>
    <main class={layoutRootClass}>
      <article>
        {
          heroAsWater ? (
            <>
              {pestInsuranceEquityNote && !isNewtownFellowshipSite ? (
                <p class="pest-equity-insurance-note">{pestInsuranceEquityNote}</p>
              ) : null}
              <section class={`${layoutRootClass}__hero`} aria-label="Service area headline">
                <Breadcrumbs
                  homeHref={internalPath()}
                  stateLabel={stateCodeFromSlug}
                  stateHref={stateCodeFromSlug ? internalPath(stateCodeFromSlug.toLowerCase()) : null}
                  cityLabel={pageCity}
                />
                <h1>
                  {isNewtownFellowshipSite ? (
                    newtownStewardshipH1Line
                  ) : zLabelExact ? (
                    pageCity ? (
                      <>
                        {waterH1Lead}
                        {`${pageCity} Emergency Dispatch - Protecting your `}
                        <span class="h1-zmoney">{zLabelExact}</span>
                        {" Asset"}
                      </>
                    ) : (
                      <>
                        {waterH1Lead}
                        {"Emergency Dispatch - Protecting your "}
                        <span class="h1-zmoney">{zLabelExact}</span>
                        {" Asset"}
                      </>
                    )
                  ) : (
                    pageH1Plain
                  )}
                </h1>
                <p style="margin: 0.25rem 0 0; color: #475569; font-size: 0.98rem;">
                  {isNewtownFellowshipSite ? newtownHeroSubline : headerVariant}
                </p>
              </section>
              {slugDispatchFeedRecords.length > 0 ? (
                <LiveDispatchFeed
                  records={slugDispatchFeedRecords}
                  title={`${stateCodeFromSlug ?? ""} Dispatch Activity Feed`}
                />
              ) : null}
            </>
          ) : heroAsPlumbing ? (
            <>
              {pestInsuranceEquityNote && !isNewtownFellowshipSite ? (
                <p class="pest-equity-insurance-note">{pestInsuranceEquityNote}</p>
              ) : null}
              <section class={`${layoutRootClass}__hero`} aria-label="Service area headline">
                <h1>
                  {isNewtownFellowshipSite ? (
                    newtownStewardshipH1Line
                  ) : isFinancialPressureMode && zLabelExact && pageCity ? (
                    <>
                      {h1ComplianceLead}
                      {"URGENT: "}
                      <span class="h1-zmoney">{zLabelExact}</span>
                      {` ${pageCity} Asset Risk | 2026 Emergency Plumbing Audit`}
                    </>
                  ) : zLabelExact ? (
                    pageCity ? (
                      <>
                        {h1ComplianceLead}
                        {`${pageCity} Emergency Dispatch - Protecting your `}
                        <span class="h1-zmoney">{zLabelExact}</span>
                        {" Asset"}
                      </>
                    ) : (
                      <>
                        {h1ComplianceLead}
                        {"Emergency Dispatch - Protecting your "}
                        <span class="h1-zmoney">{zLabelExact}</span>
                        {" Asset"}
                      </>
                    )
                  ) : (
                    pageH1Plain
                  )}
                </h1>
                <p style="margin: 0.25rem 0 0; color: #475569; font-size: 0.98rem;">
                  {isNewtownFellowshipSite ? newtownHeroSubline : headerVariant}
                </p>
              </section>
            </>
          ) : (
            <>
              {pestInsuranceEquityNote && !isNewtownFellowshipSite ? (
                <p class="pest-equity-insurance-note">{pestInsuranceEquityNote}</p>
              ) : null}
              <section class={`${layoutRootClass}__hero`} aria-label="Service area headline">
                <h1>
                  {isNewtownFellowshipSite ? (
                    newtownStewardshipH1Line
                  ) : isFinancialPressureMode ? (
                    <>
                      {`${pageCity} ${pageNicheLabel} - Property Protection: `}
                      <span class="h1-zmoney">{zLabelExact}</span>
                    </>
                  ) : zLabelExact ? (
                    pageCity ? (
                      <>
                        {`${pageCity} infrastructure stewardship — `}
                        <span class="h1-zmoney">{zLabelExact}</span>
                        {" median context"}
                      </>
                    ) : (
                      <>
                        {"Infrastructure stewardship — "}
                        <span class="h1-zmoney">{zLabelExact}</span>
                        {" median context"}
                      </>
                    )
                  ) : (
                    pageH1Plain
                  )}
                </h1>
                <p style="margin: 0.25rem 0 0; color: #475569; font-size: 0.98rem;">
                  {isNewtownFellowshipSite ? newtownHeroSubline : headerVariant}
                </p>
              </section>
            </>
          )
        }
        {
          layoutOrder.map((slot) => {
            if (slot === "risk") {
              return (
                <div class={slotShell("risk")}>
                  <OfficialRiskNodeHeader zipCode={desktopDispatchZip} />
                </div>
              );
            }
            if (slot === "vpc") {
              return (
                <div class={slotShell("vpc")}>
                  <ValueProtectionCalculator
                    homeUsd={zUsd}
                    zLabel={zLabel}
                    city={pageCity}
                    accent={themeAccent}
                    domPrefix={domPrefix}
                    presentation={
                      isNewtownFellowshipSite ? "stewardship_provision_guide" : "value_protection"
                    }
                    visualizedAssessmentLine={
                      isNewtownFellowshipSite
                        ? null
                        : heroAsWater
                          ? waterVisualLine
                          : heroAsPlumbing
                            ? plumbingVisualLine
                            : null
                    }
                    terrainRiskNotice={
                      isNewtownFellowshipSite ? null : !heroAsWater && !heroAsPlumbing ? roofTerrainNotice : null
                    }
                  />
                </div>
              );
            }
            if (slot === "logos") {
              return (
                <div class={slotShell("logos")}>
                  <NichePartnerLogos collectionKey={PAGE_COLLECTION} />
                </div>
              );
            }
            if (slot === "market") {
              return zUsd != null ? (
                <div class={slotShell("market")}>
                  <MarketDataView
                    seed={entrySlug}
                    city={pageCity}
                    state={stateCodeFromSlug}
                    zip={pageLocation?.zip ?? null}
                    homeUsd={zUsd}
                    elevationFt={typeof post.data.elevationFt === "number" ? post.data.elevationFt : undefined}
                    county={post.data.county as string | undefined}
                    accent={themeAccent}
                    medianContextCardTitle={isNewtownFellowshipSite ? "Market Context Supplement" : null}
                  />
                </div>
              ) : null;
            }
            if (slot === "faq") {
              return showFaq ? (
                <div class={slotShell("faq")}>
                  <FAQSection
                    items={pageFaqItemsForPage}
                    faqClass={`${faqClass} ${layoutRootClass}__faq`}
                    faqTitle={faqTitle}
                    faqTitleId={faqTitleId}
                  />
                </div>
              ) : null;
            }
            if (slot === "geo") {
              return showGeoSection ? (
                <div class={slotShell("geo")}>
                  <section class={`${layoutRootClass}__geo ${geoBriefClass}`} aria-labelledby={geoBriefTitleId}>
                    <h2 id={geoBriefTitleId}>{geoTitle}</h2>
                    {geoCoordsLine ? <p>{geoCoordsLine}</p> : null}
                    {geoPhysicalEnvLine ? <p>{geoPhysicalEnvLine}</p> : null}
                    {localPathsText ? <p>{localPathsText}</p> : null}
                    {geo.elevationFt ? (
                      <p>
                        {elevationLabel}: {geo.elevationFt} ft (reference band).
                      </p>
                    ) : null}
                    <p class="geo-brief-descriptor">{geoDescriptorPair[0]}</p>
                    <p class="geo-brief-descriptor">{geoDescriptorPair[1]}</p>
                    {geo.zipCodes?.length ? (
                      <div>
                        <p style="margin-bottom: 0.25rem;">{zipSnapshotLabel}</p>
                        <details>
                          <summary style="cursor: pointer; font-weight: 600;">
                            {zipViewLabel} ({geo.zipCodes.slice(0, 12).length})
                          </summary>
                          <ul style="margin: 0.55rem 0 0; padding-left: 1.25rem;">
                            {geo.zipCodes.slice(0, 12).map((z) => (
                              <li>{z}</li>
                            ))}
                          </ul>
                        </details>
                      </div>
                    ) : null}
                    {geo.localPaths?.length ? (
                      <div style="margin-top: 0.65rem;">
                        <p style="margin-bottom: 0.25rem;">{transitLabel}</p>
                        <details>
                          <summary style="cursor: pointer; font-weight: 600;">
                            {transitViewLabel} ({geo.localPaths.slice(0, 5).length})
                          </summary>
                          <ul style="margin: 0.55rem 0 0; padding-left: 1.25rem;">
                            {geo.localPaths.slice(0, 5).map((p) => (
                              <li>{p}</li>
                            ))}
                          </ul>
                        </details>
                      </div>
                    ) : null}
                  </section>
                </div>
              ) : null;
            }
            if (slot === "cas") {
              return (
                <div class={slotShell("cas")}>
                  <section class={`${layoutRootClass}__cas`} aria-labelledby={casTitleId}>
                    <h2 id={casTitleId} class={`${layoutRootClass}__cas-h`}>
                      Context-Aware Summary
                    </h2>
                    <p class={`${layoutRootClass}__cas-body`}>{contextAwareSummaryText}</p>
                  </section>
                </div>
              );
            }
            if (slot === "service") {
              return (
                <div class={slotShell("service")}>
                  <div class={`${layoutRootClass}__svc-wrap ${serviceInfoClass}`}>
                    <h2>{ctaVariant.title}</h2>
                    <p>{serviceLine}</p>
                    <p class="service-meta">{ctaVariant.meta}</p>
                    <TrustBar collectionKey={PAGE_COLLECTION} />
                    <a class={phoneBtnClass} href={telHref} aria-label={`Call ${siteConfig.phoneDisplay}`}>
                      <span class="phone-btn__main">
                        <svg
                          class="phone-btn__signal"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          width="20"
                          height="20"
                          aria-hidden="true"
                          focusable="false"
                        >
                          <g fill="currentColor">
                            <rect x="3" y="14" width="3.2" height="6" rx="0.6"></rect>
                            <rect x="8.1" y="11" width="3.2" height="9" rx="0.6"></rect>
                            <rect x="13.2" y="8" width="3.2" height="12" rx="0.6"></rect>
                            <rect x="18.3" y="5" width="3.2" height="15" rx="0.6"></rect>
                          </g>
                        </svg>
                        <span class="phone-btn__label">{callBtnLabel}</span>
                      </span>
                      <span class="phone-btn__trust">
                        National Dispatch Hub - Connecting to Local {trustDispatchPlace} Response Team.
                      </span>
                    </a>
                    <p class="phone-dispatch-zip-hint">Dispatching now for {desktopDispatchZip}</p>
                    <div class="national-dispatch-mobile-wrap">
                      <NationalDispatchDisclaimer city={pageCity} slug={entrySlug} />
                    </div>
                    <p class="dispatcher-hookup-line">
                      Regional coordination desk ({dispatcherCountyLabel}): {dispatcherClaimsLine}
                    </p>
                    {pestLatestDispatchLine ? <p class="pest-zip-dispatch-pulse">{pestLatestDispatchLine}</p> : null}
                  </div>
                </div>
              );
            }
            if (slot === "article") {
              return (
                <div class={slotShell("article")}>
                  <div id={articleBodyId} class={`${articleBodyClass} ${layoutRootClass}__article`}>
                    <div class={slotShell("meta")}>
                      <aside class={`${layoutRootClass}__meta meta-analysis-wrap`} aria-label="Meta-analysis supplement">
                        <p class="meta-analysis-line">{metaAnalysisPair[0]}</p>
                        <p class="meta-analysis-line">{metaAnalysisPair[1]}</p>
                      </aside>
                    </div>
                    <p class="engineering-notice-dynamic">
                      <strong>Engineering Notice for {engineeringNoticePlace}:</strong>{" "}
                      {engineeringNoticeClauses[0]} {engineeringNoticeClauses[1]}
                    </p>
                    <Content />
                  </div>
                </div>
              );
            }
            if (slot === "related") {
              return showRelated ? (
                <div class={slotShell("related")}>
                  <RelatedCities
                    currentSlug={entrySlug}
                    state={stateCodeFromSlug}
                    domPrefix={domPrefix}
                    themeAccent={themeAccent}
                    titleText={relatedTitle}
                    originLat={typeof post.data.lat === "number" ? post.data.lat : null}
                    originLng={typeof post.data.lng === "number" ? post.data.lng : null}
                    collectionKey={PAGE_COLLECTION}
                  />
                </div>
              ) : null;
            }
            if (slot === "microgeo") {
              return (
                <div class={slotShell("microgeo")}>
                  <p class={`${layoutRootClass}__micro micro-geo-fingerprint-line`}>{microGeoLine}</p>
                </div>
              );
            }
            return null;
          })
        }
      </article>
    </main>
    {
      isCommunityStewardshipHub ? (
        <aside
          class="outreach-grant-compliance-disclaimer"
          role="note"
          aria-label="Infrastructure and data disclosure"
        >
          <p>
            Technical risk assessment infrastructure and localized data telemetry provided by the Rockwell
            Infrastructure Group via a digital outreach grant. For immediate physical mitigation, our community desk
            routes inquiries through verified response networks.
          </p>
        </aside>
      ) : null
    }
    <Footer
      extraLink={footerExtraLink}
      notice={stateNotice}
      variantSeed={`${PAGE_COLLECTION}|${entrySlug}|footer`}
      slug={entrySlug}
      auditStateCode={slugGeoTailForPhysical?.state}
      auditZipCode={slugGeoTailForPhysical?.zip}
      auditNodeVersion={auditNodeFingerprintVersion}
      collectionKey={PAGE_COLLECTION}
    />
    <DispatchCommandBar
      city={pageLocation?.city ?? pageCity ?? "Local"}
      zip={(pageLocation?.zip ?? String(post.data.zipCode ?? "").trim()) || "00000"}
      nicheLabel={pageNicheLabel}
      slugSeed={entrySlug}
      stickyVariant={isNewtownFellowshipSite ? "newtown_fellowship" : "default"}
      collectionKey={PAGE_COLLECTION}
    />
  </body>
</html>
