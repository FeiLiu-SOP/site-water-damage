    base.unshift(`Critical ${short}`);
  }
  const r = baitPickRaw % Math.max(1, base.length);
  const rotated = [...base.slice(r), ...base.slice(0, r)];
  return clipAssetDefenseTitle60(zLabel, pageCity, rotated);
}

