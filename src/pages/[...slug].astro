const domPrefix = ACTIVE_COLLECTION === "plumbing-v2"
  ? `${REALTORS_AT_THE_BEACH_PLUMBING_V2.domPrefixBase}-${stableHash(
      `${siteConfig.canonicalOrigin}|${entrySlug}|dom`,
