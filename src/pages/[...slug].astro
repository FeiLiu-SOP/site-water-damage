 * Compression protocol: truncate Service only; never truncate zLabel or City.
 */
const SERP_ASSET_DEFENSE_SERVICES: Record<ActiveCollectionKey, readonly string[]> = {
  roofing: ["Emergency Roofing (Rapid Response)", "Emergency Roofing", "Roofing"],
  plumbing: ["Emergency Plumbing (Rapid Response)", "Emergency Plumbing", "Plumbing"],
  pestcontrol: ["Emergency Pest Control (Rapid)", "Emergency Pest Control", "Pest Control"],
  "water-damage": ["Emergency Water Damage (Rapid)", "Emergency Water Damage", "Water Damage"],
  "siding-services": ["Emergency Siding (Rapid Response)", "Emergency Siding", "Siding"],
  "plumbing-v2": ["Emergency Plumbing (Rapid Response)", "Emergency Plumbing", "Plumbing"],
};

function clipAssetDefenseTitle60(
  zLabelForTitle: string | null,
  cityRaw: string | null,
  serviceCandidates: string[],
): string {
  const tail = ` | ${SERP_TITLE_BRAND}`;
  const assetPrefix = zLabelForTitle ? `${zLabelForTitle} Asset Defense: ` : `Asset Defense: `;
  const city = (cityRaw ?? "Local").replace(/\s+/g, " ").trim();

  const assemble = (svc: string) => {
    const s = svc.replace(/\s+/g, " ").trim();
    const mid = s ? `${city} ${s}` : city;
    return `${assetPrefix}${mid}${tail}`;
  };

  const seen = new Set<string>();
  const pool: string[] = [];
  for (const c of serviceCandidates) {
    const k = c.replace(/\s+/g, " ").trim();
    if (!k || seen.has(k)) continue;
    seen.add(k);
    pool.push(k);
  }
  pool.sort((a, b) => b.length - a.length);

  for (const svc of pool) {
    const t = assemble(svc);
    if (t.length <= 60) return t;
  }

  let svc = pool[pool.length - 1] ?? "Service";
  svc = svc.trim();
  while (svc.length > 0 && assemble(svc).length > 60) {
    svc = svc.slice(0, -1).replace(/[\s(/,.-]+$/, "").trimEnd();
  }
  let out = assemble(svc);
  if (out.length <= 60) return out;

  out = assemble("");
  if (out.length <= 60) return out;

  return assemble("").slice(0, 60);
}

function buildAssetDefenseSerpTitle(): string {
  const base = [...SERP_ASSET_DEFENSE_SERVICES[ACTIVE_COLLECTION]];
  if (isFinancialPressureMode) {
