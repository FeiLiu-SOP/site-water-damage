/** Fisher–Yates (seeded) shuffle — seed from slug for layout decoupling. */
function fisherYatesLayoutKeys<T extends string>(keys: T[], seedStr: string): T[] {
  const arr = [...keys];
  let s = stableHash(seedStr);
  for (let i = arr.length - 1; i > 0; i--) {
    s = Math.imul(s ^ (s >>> 11), 2654435761) >>> 0;
    const j = s % (i + 1);
    const a = arr[i]!;
    const b = arr[j]!;
    arr[i] = b;
    arr[j] = a;
  }
  return arr;
}

/** Per-section CSS jitter token (valid class lead char). */
function sectionShellClass(slug: string, sectionKey: string): string {
  const n = stableHash(`${slug}|${sectionKey}|jit`);
  return `jit${(n >>> 0).toString(16).padStart(8, "0").slice(0, 7)}`;
}

function slotShell(sectionKey: string): string {
