  ? `Notice: This ${stateCodeFromSlug} page summarizes regional infrastructure maintenance coordination and local topographic context; it is not a government bulletin.`
  : "Notice: This page summarizes regional infrastructure maintenance coordination and local topographic context; it is not a government bulletin.";
const telHref = `tel:${siteConfig.phoneE164.replace(/^\+/, "")}`;
const dispatcherCountyLabel = (
  String(post.data.county ?? "").trim() ||
  (pageCity && stateCodeFromSlug ? `${pageCity}, ${stateCodeFromSlug}` : stateCodeFromSlug ?? "Regional")
).trim();
const dispatcherClaimsLine =
  "Scheduling visibility depends on confirmed technician availability; this page does not display simulated queue depth.";

/** Pest-control only: insurance / termite equity line (below calculator “price”). */
const pageZipForPestPulse = (() => {
  const fromFm = String(post.data.zipCode ?? "").trim();
  if (/^\d{5}$/.test(fromFm)) return fromFm;
  const m = entrySlug.match(/-(\d{5})$/i);
  return m?.[1] ?? null;
})();
const pestInsuranceEquityNote =
  ACTIVE_COLLECTION === "pestcontrol"
    ? (() => {
        const stateTok = stateCodeFromSlug
          ? stateLabelForBait(stateCodeFromSlug, post.data.state)
          : "your state";
        const equityPart = zLabelExact ? `${zLabelExact} equity` : zLabel ? `${zLabel} equity` : "home equity";
        return `Note: Standard homeowners insurance in ${stateTok} typically excludes Termite structural damage. Protect your ${equityPart} now.`;
      })()
    : null;
const pestLatestDispatchLine =
  ACTIVE_COLLECTION === "pestcontrol" && pageZipForPestPulse
    ? `Educational note for ZIP ${pageZipForPestPulse}: termite pressure varies by season—ask your coordinator for inspection-backed guidance (not a live incident feed).`
    : null;

// Action 3: Geo brief section data from frontmatter (truthy only; Astro just displays)
const geo = {
  county: post.data.county as string | undefined,
  elevationFt: typeof post.data.elevationFt === "number" ? post.data.elevationFt : undefined,
  lat: typeof post.data.lat === "number" ? post.data.lat : undefined,
  lng: typeof post.data.lng === "number" ? post.data.lng : undefined,
  zipSample: Array.isArray(post.data.zipSample) ? post.data.zipSample : undefined,
  zipCodes: Array.isArray(post.data.zipCodes) ? post.data.zipCodes : undefined,
  localPaths: Array.isArray(post.data.localPaths) ? post.data.localPaths : undefined,
};
const stateGeoFact = getStatePhysicalEnvironmentFact(stateCodeFromSlug);
const geoCoordsLine =
  geo.county && typeof geo.lat === "number" && typeof geo.lng === "number"
    ? `Regional infrastructure brief: ${geo.county}. Coordinates ${geo.lat.toFixed(4)}, ${geo.lng.toFixed(4)}.${
        (geo.zipSample ?? []).filter(Boolean).length
          ? ` Sample ZIP codes: ${(geo.zipSample ?? []).slice(0, 5).join(", ")}.`
          : ""
      }`
    : null;
const geoPhysicalEnvLine = stateCodeFromSlug
  ? `Physical environment context (${stateGeoFact.label}): ${stateGeoFact.narrative}`
  : null;
const showGeoSection = Boolean(geoCoordsLine || geoPhysicalEnvLine);
const localPathsText =
  geo.localPaths && geo.localPaths.length
    ? `Regional access notes: ${geo.localPaths.slice(0, 5).join(", ")}.`
    : null;

function addendumForFaq(seedText: string) {
  const pool = [
    geo.county ? `Local note: County context — ${geo.county}.` : null,
    geo.zipSample?.length ? `Local note: Sample ZIP sectors — ${(geo.zipSample ?? []).slice(0, 5).join(", ")}.` : null,
    stateCodeFromSlug ? `Local note: State routing node — ${stateCodeFromSlug}.` : null,
    typeof geo.lat === "number" && typeof geo.lng === "number"
      ? `Local note: Coordinate anchor — ${geo.lat.toFixed(4)}, ${geo.lng.toFixed(4)}.`
      : null,
    geo.localPaths?.length ? `Local note: Transit markers — ${(geo.localPaths ?? []).slice(0, 2).join("; ")}.` : null,
  ].filter(Boolean) as string[];
  if (!pool.length) return null;
  return stableHash(seedText) % 2 === 0 ? pool[stableHash(seedText + "|p") % pool.length]! : null;
}

const pageFaqItemsFinal = pageFaqItems.map((item, idx) => {
  const add = addendumForFaq(`${ACTIVE_COLLECTION}|${entrySlug}|faqAdd|${idx}`);
  return {
    question: item.question,
    answer: add ? `${item.answer} ${add}` : item.answer,
  };
});

const enableRealtorsAtTheBeachWaterDamageIsolation = matchesRealtorsAtTheBeachWaterDamage({
