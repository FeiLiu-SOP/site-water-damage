---
import { getCollection, render } from "astro:content";
import Footer from "../components/Footer.astro";
import RelatedCities from "../components/RelatedCities.astro";
import { ACTIVE_COLLECTION } from "../active-collection";
import { canonicalPageUrl, siteConfig } from "../site-config";
import {
  buildFaqSchema,
  buildLocalBusinessSchema,
  getFaqByCollection,
} from "../lib/seo";
import { resolvePageLocation } from "../lib/location";

export async function getStaticPaths() {
  const posts = await getCollection(ACTIVE_COLLECTION);
  return posts.map((post) => ({
    params: { slug: (post.slug ?? post.id ?? "").replace(/\.(md|mdx)$/i, "") },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);
const entrySlug = (post.slug ?? post.id ?? "").replace(/\.(md|mdx)$/i, "");
const pageUrl = canonicalPageUrl(entrySlug);
const pageLocation = resolvePageLocation({
  collection: ACTIVE_COLLECTION,
  title: post.data.title,
  slug: entrySlug,
  fmCity: post.data.city,
  fmState: post.data.state,
  fmZip: post.data.zipCode,
});
const faqItems = getFaqByCollection(ACTIVE_COLLECTION);
const localBusinessSchema = buildLocalBusinessSchema({
  collection: ACTIVE_COLLECTION,
  pageTitle: post.data.title,
  pageDescription: post.data.description,
  pageUrl,
  location: pageLocation,
});
const telHref = `tel:${siteConfig.phoneE164.replace(/^\+/, "")}`;
const faqSchema = buildFaqSchema(faqItems);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="e8639489520c639b" />
    <title>{post.data.title}</title>
    <meta name="description" content={post.data.description} />
    <meta name="robots" content={siteConfig.robotsContent} />
    {post.data.templateVersion ? (
      <meta name="template-version" content={post.data.templateVersion} />
    ) : null}
    <link rel="canonical" href={pageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <style>
      :root {
        color-scheme: light;
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      body {
        margin: 0;
        background: #f8fafc;
        color: #0f172a;
      }
      main {
        width: min(800px, 92vw);
        margin: 2rem auto;
        background: #fff;
        border-radius: 12px;
        padding: 2rem 1.25rem;
        box-shadow: 0 8px 30px rgba(2, 6, 23, 0.08);
      }
      h1 {
        line-height: 1.2;
        margin-top: 0;
      }
      .service-info {
        margin: 1.5rem 0 2rem;
        padding: 1.25rem 1.4rem;
        background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
        border: 1px solid #cbd5e1;
        border-left: 6px solid #0f172a;
        border-radius: 10px;
      }
      .service-info h2 {
        margin: 0 0 0.5rem;
        font-size: 1.25rem;
      }
      .service-info p {
        margin: 0.25rem 0;
        color: #334155;
      }
      .service-meta {
        font-size: 0.95rem;
      }
      .phone-btn {
        display: inline-block;
        margin-top: 0.8rem;
        background: #dc2626;
        color: #fff;
        padding: 0.7rem 1rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
      }
      .phone-btn:hover {
        background: #b91c1c;
      }
      .faq {
        margin-top: 2rem;
        border-top: 1px solid #e2e8f0;
        padding-top: 1rem;
      }
      .faq h2 {
        margin: 0 0 0.75rem;
      }
      .faq details {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #f8fafc;
        margin-bottom: 0.6rem;
        padding: 0.6rem 0.8rem;
      }
      .faq summary {
        cursor: pointer;
        font-weight: 600;
      }
      .faq p {
        margin: 0.55rem 0 0.1rem;
        color: #334155;
      }
    </style>
  </head>
  <body>
    <main>
      <article>
        <h1>{post.data.title}</h1>
        <div class="service-info">
          <h2>24/7 Local {siteConfig.nicheLabel} Emergency Service</h2>
          <p>
            Licensed local technicians available for urgent{" "}
            {siteConfig.nicheLabel.toLowerCase()} service calls and emergency
            response.
          </p>
          <p class="service-meta">Fast dispatch, transparent pricing, and free inspection availability.</p>
          <a class="phone-btn" href={telHref}>
            Call Now: {siteConfig.phoneDisplay}
          </a>
        </div>
        <Content />
        <section class="faq" aria-labelledby="faq-title">
          <h2 id="faq-title">Frequently Asked Questions</h2>
          {
            faqItems.map((item) => (
              <details>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))
          }
        </section>
        <RelatedCities currentSlug={entrySlug} state={pageLocation?.state} />
      </article>
    </main>
    <Footer />
  </body>
</html>
