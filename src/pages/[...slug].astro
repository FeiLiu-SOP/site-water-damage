  : enableRealtorsAtTheBeachWaterDamageIsolation
    ? `${REALTORS_AT_THE_BEACH_WATER_DAMAGE.domPrefixBase}-${stableHash(
        `${siteConfig.canonicalOrigin}|${entrySlug}|dom`,
      )}`
    : null;

const articleBodyId = domPrefix ? `${domPrefix}-article-md-body` : "article-md-body";
const articleBodyClass = domPrefix ? `${domPrefix}--article-content` : "article-content";

const serviceInfoClass = domPrefix ? `${domPrefix}--service-info` : "service-info";
const phoneBtnClass = domPrefix ? `${domPrefix}--phone-btn` : "phone-btn";
const geoBriefClass = domPrefix ? `${domPrefix}--geo-brief` : "geo-brief";
const faqClass = domPrefix ? `${domPrefix}--faq` : "faq";

const geoBriefTitleId = domPrefix ? `${domPrefix}-geo-brief-title` : "geo-brief-title";
const faqTitleId = domPrefix ? `${domPrefix}-faq-title` : "faq-title";

const localBusinessSchema = isRockwellMaine
  ? buildRockwellMaineEntityGraph({
      collection: ACTIVE_COLLECTION,
      pageDescription: pageMetaDescription,
      pageUrl,
      location: pageLocation,
    })
  : buildLocalBusinessSchema({
      collection: ACTIVE_COLLECTION,
      pageTitle,
      pageDescription: pageMetaDescription,
      pageUrl,
      location: pageLocation,
    });
const faqSchema = buildFaqSchema(pageFaqItemsFinal);

const breadcrumbListSchema = buildBreadcrumbListSchema(
  buildSlugPageBreadcrumbItems({
    canonicalPageUrl,
    serviceHubLabel: PUBLIC_NICHE_LABEL,
    stateCode: stateCodeFromSlug,
    cityDisplayName: pageCity,
    entrySlug,
  }),
);

// Action 3: stable DOM section randomizer for 4 blocks (content / geo / faq / related)
const blocks = ["content", "geo", "faq", "related"] as const;
const visibleBlocks = blocks.filter((k) => {
  if (k === "faq") return showFaq;
  if (k === "related") return showRelated;
  return true;
});
const blockOrder = ACTIVE_COLLECTION === "plumbing-v2"
  ? REALTORS_AT_THE_BEACH_PLUMBING_V2.blockOrder.filter((k) => visibleBlocks.includes(k))
  : enableRealtorsAtTheBeachWaterDamageIsolation
  ? REALTORS_AT_THE_BEACH_WATER_DAMAGE.blockOrder.filter((k) => visibleBlocks.includes(k))
  : (() => {
      const orderSeed = stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|order`);
      const order = [...visibleBlocks];
      {
        let s = orderSeed;
        for (let i = order.length - 1; i > 0; i--) {
          s = Math.imul(s ^ (s >>> 13), 1274126177) >>> 0;
          const j = s % (i + 1);
          const a = order[i]!;
          const b = order[j]!;
          order[i] = b;
          order[j] = a;
        }
      }
      return order;
    })();
